# Copy this to .env.local and fill in real values
# Get Supabase values from: https://supabase.com/dashboard → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Pick any random string (e.g. run: openssl rand -hex 32)
GITHUB_WEBHOOK_SECRET=change-me-to-random-string

# Optional — leave blank if you don't want Slack notifications yet
SLACK_WEBHOOK_URL=

# Random string to protect the cron endpoint
CRON_SECRET=change-me-to-another-random-string
